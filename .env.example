# CrisisSync — Environment variables
# Copy to .env and fill in your values.
#
# For Vercel: add these in Project → Settings → Environment Variables

# ── Required ──────────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_replace_with_a_32_char_random_string

# SQLite (local dev — zero config, auto-created)
DATABASE_URL=sqlite+aiosqlite:///./crisissync.db

# For Vercel + Vercel Postgres / Neon / Supabase, use:
# DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# ── App ───────────────────────────────────────────────────────────────────────

ENVIRONMENT=development
DEBUG=true

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * to allow all
CORS_ORIGINS=*

# ── Twilio SMS (optional) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
